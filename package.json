{
  "name": "badvibes",
  "version": "0.2.0",
  "description": "Lint for AI slop. Audits a repo and prints a Vibe Score from 0 to 100.",
  "keywords": [
    "cli",
    "lint",
    "linter",
    "audit",
    "code-quality",
    "code-review",
    "ai",
    "ai-code",
    "vibe-coding",
    "vibe-score",
    "bad-vibes",
    "repo-health",
    "developer-tools",
    "technical-debt",
    "typescript",
    "nodejs"
  ],
  "license": "MIT",
  "author": "marco-trotta1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marco-trotta1/vibescore.git"
  },
  "bugs": {
    "url": "https://github.com/marco-trotta1/vibescore/issues"
  },
  "homepage": "https://github.com/marco-trotta1/vibescore#readme",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "badvibes": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "figlet": "1.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
